{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": ["src/**/*"]
}